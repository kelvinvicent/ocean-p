# ─────────────────────────────────────────────────────────────────
# Configuración de base de datos
# ─────────────────────────────────────────────────────────────────
# Desarrollo local (SQLite, sin config extra):
DATABASE_URL=sqlite:///./ocean_p.db

# Producción (Neon / PostgreSQL). El connection string viene de
# https://console.neon.tech → Project → Connection Details.
# Formato típico (con SSL obligatorio en Neon):
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─────────────────────────────────────────────────────────────────
# API Key de Resend (para envío de emails — Fase 2)
# ─────────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─────────────────────────────────────────────────────────────────
# Clave secreta para seguridad y firma de tokens
# ─────────────────────────────────────────────────────────────────
SECRET_KEY=local_development_secret_key_change_me_in_production
